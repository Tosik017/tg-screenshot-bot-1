# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Порт HTTP-сервера (на Render задаётся автоматически; локально 8000)
PORT=8000

# Разрешённые группы. Можно НЕСКОЛЬКО — через запятую или пробел.
# Бот обрабатывает ссылки только в этих группах, из любой другой выходит сам.
# Пусто = ограничение ВЫКЛЮЧЕНО (бот работает везде).
# Как узнать ID: оставь пустым, добавь бота в группу, в логах Render будет строка
#   MY_CHAT_MEMBER chat_id=-100... — это ID. Топики указывать НЕ нужно: один ID =
#   вся группа со всеми её топиками. Супергруппа имеет отрицательный ID -100...
ALLOWED_GROUP_IDS=-1001111111111,-1002222222222

# (необязательно) Старая одиночная переменная всё ещё поддерживается и
# объединяется со списком выше:
# ALLOWED_GROUP_ID=-1001111111111
