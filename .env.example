# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Порт HTTP-сервера (на Render задаётся автоматически; локально по умолчанию 8000)
PORT=8000

# ID единственной разрешённой группы. Бот обрабатывает ссылки только здесь,
# из любого другого чата выходит автоматически.
# 0 или пусто = ограничение ВЫКЛЮЧЕНО (бот работает везде).
# Как узнать ID: оставь 0, добавь бота в группу, посмотри в логах Render строку
#   MY_CHAT_MEMBER chat_id=-100... — это и есть ID. Впиши его и передеплой.
# Супергруппа имеет отрицательный ID вида -1001234567890.
ALLOWED_GROUP_ID=0
